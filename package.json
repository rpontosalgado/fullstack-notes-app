{
  "name": "notes-app",
  "packageManager": "yarn@4.14.1",
  "devDependencies": {
    "@commitlint/cli": "^21.0.0",
    "@commitlint/config-conventional": "^21.0.0",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "husky": "^9.1.7"
  },
  "scripts": {
    "prepare": "husky",
    "dev": "yarn workspace @notes-app/backend start:dev & yarn workspace @notes-app/frontend dev",
    "dev:backend": "yarn workspace @notes-app/backend start:dev",
    "dev:frontend": "yarn workspace @notes-app/frontend dev",
    "build": "yarn workspace @notes-app/backend build && yarn workspace @notes-app/frontend build",
    "build:backend": "yarn workspace @notes-app/backend build",
    "build:frontend": "yarn workspace @notes-app/frontend build",
    "test": "yarn workspace @notes-app/backend run jest --passWithNoTests && yarn workspace @notes-app/frontend test",
    "test:backend": "yarn workspace @notes-app/backend run jest --passWithNoTests",
    "test:frontend": "yarn workspace @notes-app/frontend test",
    "lint": "yarn workspace @notes-app/backend lint && yarn workspace @notes-app/frontend lint",
    "lint:backend": "yarn workspace @notes-app/backend lint",
    "lint:frontend": "yarn workspace @notes-app/frontend lint"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "private": true,
  "workspaces": [
    "packages/*"
  ]
}
